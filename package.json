{
  "name": "substreak",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --bundles msi,nsis",
    "version:check": "node ./scripts/version.mjs check",
    "version:check-notes": "node ./scripts/version.mjs check-notes",
    "version:sync": "node ./scripts/version.mjs sync",
    "version:set": "node ./scripts/version.mjs set",
    "version:patch": "node ./scripts/version.mjs patch",
    "version:minor": "node ./scripts/version.mjs minor",
    "version:major": "node ./scripts/version.mjs major",
    "release:windows": "bun run tauri:build:windows && node ./scripts/package-release.mjs",
    "release:publish": "bun run release:windows && node ./scripts/publish-release.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-process": "^2.0.1",
    "@tauri-apps/plugin-updater": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "ssh2-sftp-client": "^11.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
