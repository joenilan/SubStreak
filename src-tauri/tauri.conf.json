{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SubStreak",
  "mainBinaryName": "substreak",
  "version": "0.1.0",
  "identifier": "com.dreadedzombie.substreak",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SubStreak",
        "width": 480,
        "height": 660,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "backgroundColor": "#0a0b10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "DreadedZombie",
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "43a80ddf-9a2e-4b68-a56c-7a9072ae95df"
      }
    }
  }
}
