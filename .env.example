# Copy to .env and fill in.

# Twitch Client ID — a public client identifier (device-code flow, no secret).
# Register an app at https://dev.twitch.tv/console/apps
VITE_TWITCH_CLIENT_ID=

# Tauri updater signing (release/publish step). Generate with:
#   cd apps/substreak && bunx tauri signer generate --ci -w "$HOME/.tauri/substreak.key"
# Then paste the public key (the .pub file content) into src-tauri/tauri.conf.json plugins.updater.pubkey
TAURI_SIGNING_PRIVATE_KEY_PATH=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Server upload for publishing
SSH_HOST=
SSH_USER=
SSH_PASSWORD=
SSH_PORT=22
RELEASE_APP_SLUG=substreak
